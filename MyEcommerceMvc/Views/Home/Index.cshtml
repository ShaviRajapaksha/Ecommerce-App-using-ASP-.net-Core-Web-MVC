@using System.Linq
@model List<MyEcommerceMvc.Models.Order>

@{
    ViewData["Title"] = "Dashboard";
}

<div class="row mb-4">
    <div class="col-md-4 mb-3">
        <div class="card card-stats bg-primary text-white">
            <div class="card-body">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <h5 class="card-title">Total Products</h5>
                        <h2 class="mb-0">@ViewBag.TotalProducts</h2>
                    </div>
                    <i class="fas fa-box fa-3x opacity-50"></i>
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-4 mb-3">
        <div class="card card-stats bg-success text-white">
            <div class="card-body">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <h5 class="card-title">Total Orders</h5>
                        <h2 class="mb-0">@ViewBag.TotalOrders</h2>
                    </div>
                    <i class="fas fa-shopping-cart fa-3x opacity-50"></i>
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-4 mb-3">
        <div class="card card-stats bg-info text-white">
            <div class="card-body">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <h5 class="card-title">Total Users</h5>
                        <h2 class="mb-0">@ViewBag.TotalUsers</h2>
                    </div>
                    <i class="fas fa-users fa-3x opacity-50"></i>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="card">
    <div class="card-header">
        <h5><i class="fas fa-clock"></i> Recent Orders</h5>
    </div>
    <div class="card-body">
        @if (Model != null && Model.Any())
        {
            <div class="table-responsive">
                <table class="table table-hover">
                    <thead>
                        <tr>
                            <th>Order ID</th>
                            <th>Customer</th>
                            <th>Date</th>
                            <th>Status</th>
                            <th>Total</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var order in Model)
                        {
                            <tr>
                                <td>#@order.Id</td>
                                <td>@(order.User?.Username ?? "N/A")</td>
                                <td>@order.OrderDate.ToString("MMM dd, yyyy")</td>
                                <td>
                                    <span class="badge bg-@order.StatusBadgeClass">@order.Status</span>
                                </td>
                                <td>@order.TotalAmount.ToString("C")</td>
                                <td>
                                    <a href="/Orders/Details/@order.Id" class="btn btn-sm btn-info">
                                        <i class="fas fa-eye"></i> View
                                    </a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
        else
        {
            <div class="alert alert-info">
                <i class="fas fa-info-circle"></i> No orders found. 
                <a href="/Orders/Create" class="alert-link">Create your first order</a>
            </div>
        }
    </div>
</div>

<div class="row mt-4">
    <div class="col-md-6 mb-3">
        <div class="card">
            <div class="card-header">
                <h5><i class="fas fa-chart-line"></i> Quick Actions</h5>
            </div>
            <div class="card-body">
                <div class="d-grid gap-2">
                    <a href="/Products/Create" class="btn btn-outline-primary">
                        <i class="fas fa-plus"></i> Add New Product
                    </a>
                    <a href="/Users/Create" class="btn btn-outline-success">
                        <i class="fas fa-user-plus"></i> Register New User
                    </a>
                    <a href="/Orders/Create" class="btn btn-outline-info">
                        <i class="fas fa-shopping-cart"></i> Create New Order
                    </a>
                    <a href="/Categories/Create" class="btn btn-outline-warning">
                        <i class="fas fa-tag"></i> Add New Category
                    </a>
                </div>
            </div>
        </div>
    </div>
    
    <div class="col-md-6 mb-3">
        <div class="card">
            <div class="card-header">
                <h5><i class="fas fa-info-circle"></i> System Information</h5>
            </div>
            <div class="card-body">
                <ul class="list-group list-group-flush">
                    <li class="list-group-item d-flex justify-content-between align-items-center">
                        Database Status
                        <span class="badge bg-success">Connected</span>
                    </li>
                    <li class="list-group-item d-flex justify-content-between align-items-center">
                        Relationships Demo
                        <span class="badge bg-info">1-to-1, 1-to-Many, Many-to-Many</span>
                    </li>
                    <li class="list-group-item d-flex justify-content-between align-items-center">
                        API Documentation
                        <a href="/swagger" target="_blank" class="btn btn-sm btn-link">Swagger UI</a>
                    </li>
                </ul>
            </div>
        </div>
    </div>
</div>

<style>
    .card-stats {
        transition: transform 0.2s;
        cursor: pointer;
    }
    .card-stats:hover {
        transform: translateY(-5px);
        box-shadow: 0 4px 8px rgba(0,0,0,0.1);
    }
    .opacity-50 {
        opacity: 0.5;
    }
</style>